# Copiar este archivo a `env.turso` (esta ruta esta en .gitignore) y rellenar con
# los mismos valores que en Netlify → Environment variables.
# Luego: npm run db:push:turso   (aplicara el esquema a Turso, no a data/dev.db)

DATABASE_URL=libsql://TU-DATABASE-ORG.turso.io
TURSO_AUTH_TOKEN=TU_TOKEN_DE_TURSO
DB_PROVIDER=turso
