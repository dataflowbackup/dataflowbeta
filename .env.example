# ---------------------------------------------------------------------------
# Desarrollo LOCAL habitual (sin Docker, sin Postgres): SQLite en archivo
# ---------------------------------------------------------------------------
DB_PROVIDER=sqlite
DATABASE_URL=file:./data/dev.db
SESSION_SECRET=genera_una_cadena_larga_aleatoria
NODE_ENV=development
PORT=3000

# Copiá a .env.local o usá solo .env.local con estos valores.

# Si necesitás cargar el backup grande (dataflow_db_backup.sql), ese archivo es
# PostgreSQL — no entra en SQLite. Opción: Postgres instalado en Windows; ver docs/LOCAL-POSTGRES.md

# Turso (solo variables en Netlify para producción, o si corrés db:push:turso):
# DB_PROVIDER=turso
# DATABASE_URL=libsql://...
# TURSO_AUTH_TOKEN=...

# SESSION_COOKIE_SECURE=false
# (solo si en local tenés NODE_ENV=production por error y la cookie no se guarda)

# Seed inicial (opcional)
# SEED_CLIENT_NAME=DataFlow Beta
# SEED_LOCAL_NAME=Casa Central
# SEED_ADMIN_EMAIL=admin@dataflow.local
# SEED_ADMIN_USERNAME=admin
# SEED_ADMIN_PASSWORD=CAMBIAR_ESTA_CLAVE
# SEED_ADMIN_FIRST_NAME=Admin
# SEED_ADMIN_LAST_NAME=DataFlow
